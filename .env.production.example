# Production environment — reference template.
# The real file lives ONLY on the droplet at /home/jarvis/anjaneya/.env
# (mode 600) and is NEVER committed.

# Django
SECRET_KEY=                              # python -c "import secrets; print(secrets.token_urlsafe(50))"
DEBUG=False
DJANGO_SETTINGS_MODULE=core.settings.production
ALLOWED_HOSTS=anjaneyaglobalrealty.com,www.anjaneyaglobalrealty.com

# Database (PostgreSQL installed on the droplet)
DB_NAME=anjaneya
DB_USER=anjaneya
DB_PASSWORD=                             # set during provisioning — see runbook / /root/anjaneya-db-password.txt
DB_HOST=127.0.0.1
DB_PORT=5432

# Redis (local on the droplet)
REDIS_URL=redis://127.0.0.1:6379/0

# Logging — directory provision.sh creates and chowns to jarvis:jarvis.
# production.py falls back to this same path if the var is omitted.
LOG_DIR=/var/log/anjaneya

# Security
CSRF_TRUSTED_ORIGINS=https://anjaneyaglobalrealty.com,https://www.anjaneyaglobalrealty.com
CORS_ALLOWED_ORIGINS=https://anjaneyaglobalrealty.com,https://www.anjaneyaglobalrealty.com

# Email (SMTP)
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Anjaneya Global Realty <no-reply@anjaneyaglobalrealty.com>
DJANGO_ADMINS=Admin:admin@anjaneyaglobalrealty.com

# Sentry (optional — leave blank to disable)
SENTRY_DSN=
SENTRY_ENV=production
